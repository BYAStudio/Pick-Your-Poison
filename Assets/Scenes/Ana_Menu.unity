  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Bardak i\xE7mekten ka\xE7man\u0131n tek yolu kart \xE7ekmektir. \xC7ekti\u011Fin
    kartlara g\xF6re \u015Fu etkiler uygulan\u0131r:\n\n\u2022 <b>A\xE7g\xF6zl\xFCl\xFCk
    Cezas\u0131:</b> Masadan se\xE7ti\u011Fin 2 barda\u011F\u0131 i\xE7mek zorunda
    kal\u0131rs\u0131n.\n\u2022 <b>Kritik Doz:</b> Do\u011Frudan zehirlenirsin.\n\u2022
    <b>Zehir Tarama:</b> Se\xE7ilen 2x2 alandaki zehirli bardak say\u0131s\u0131n\u0131
    t\xFCm oyunculara g\xF6sterir.\n\u2022 <b>Panzehir Tarama:</b> Se\xE7ilen 2x2
    alandaki panzehirli bardak say\u0131s\u0131n\u0131 sadece sana g\xF6sterir.\n\u2022
    <b>Girdap:</b> Turun d\xF6n\xFC\u015F y\xF6n\xFCn\xFC tersine \xE7evirir.\n\u2022
    <b>Nefeslenme:</b> Turunu hi\xE7bir risk almadan g\xFCvenle pas ge\xE7ersin.\n\u2022
    <b>Zoraki \u0130kram:</b> Masadan se\xE7ece\u011Fin 1 barda\u011F\u0131 ba\u015Fka
    bir oyuncuya zorla i\xE7irirsin."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 2e498d1c8094910479dc3e1b768306a4, type: 2}
